@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="apple-touch-icon" href="/images/logo.png" />
    <link rel="shortcut icon" href="/images/logo.png" />
    <title>ABG Production Dispatch</title>

   
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <style>
        @@font -face {
            font-family: 'DM Sans';
            src: url('/fonts/DMSans-Regular.ttf') format('truetype');
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }
        @@font -face {
            font-family: 'DM Sans';
            src: url('/fonts/DMSans-Medium.ttf') format('truetype');
            font-weight: 500;
            font-style: normal;
            font-display: swap;
        }
        @@font -face {
            font-family: 'DM Sans';
            src: url('/fonts/DMSans-SemiBold.ttf') format('truetype');
            font-weight: 600;
            font-style: normal;
            font-display: swap;
        }
        @@font -face {
            font-family: 'DM Sans';
            src: url('/fonts/DMSans-Bold.ttf') format('truetype');
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }
        @@font -face {
            font-family: 'Space Grotesk';
            src: url('/fonts/SpaceGrotesk-Bold.ttf') format('truetype');
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }
    </style>
   


    <link rel="stylesheet" href="~/css/dispatch.css" />
</head>
<body>

<!-- =============================================
     TOPBAR
============================================= -->
<header class="topbar">
    <div class="topbar-left">
        <div class="logo-box">
            <img src="/images/logo.png"
                 alt="ABG"
                 onerror="this.style.display='none';document.getElementById('logoFallback').style.display='flex';" />
            <span id="logoFallback" class="logo-fallback">AB</span>
        </div>
        <div class="brand">
            <span class="brand-name">Aditya Birla Group</span>
            <span class="brand-sub">Production Dispatch System</span>
        </div>
    </div>
    <div class="topbar-right">
             <span class="plant-badge">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" />
                    <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
                    <line x1="12" y1="12" x2="12" y2="16" />
                    <line x1="10" y1="14" x2="14" y2="14" />
                </svg>
                Plant 1
            </span>
       <!-- <div class="avatar" title="Operator">OP</div> -->
    </div>
</header>


<!-- =============================================
     MAIN CONTENT
============================================= -->
<main class="main">

    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">Dispatch <span>Console</span></h1>
        <div class="page-date" id="liveDate"></div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
        <div class="stat-card">
                <div class="stat-icon red">
                    <!-- Box / Package icon -->
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D0021B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                        <line x1="12" y1="22.08" x2="12" y2="12" />
                    </svg>
                </div>
            <div class="stat-body">
                <div class="stat-val" id="statScanned">0</div>
                <div class="stat-key">Scanned</div>
            </div>
        </div>
        
           
          <!--  <div class="stat-card">
                <div class="stat-icon blue">
                   
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="5" r="3" />
                <line x1="12" y1="8" x2="12" y2="20" />
                <path d="M5 20h14" />
                <path d="M5 12l7-4 7 4" />
                </svg>
                 </div>
                <div class="stat-body">
                <div class="stat-val" id="statWeight">0</div>
                <div class="stat-key">Wt. (kg)</div>
                 </div>
            </div> -->
        
        <div class="stat-card">
                <div class="stat-icon green">
                    <!-- Checkmark / Confirmed icon -->
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                </div>
            <div class="stat-body">
                <div class="stat-val" id="statConfirmed">0</div>
                <div class="stat-key">Confirmed</div>
            </div>
        </div>
    </div>

    <!-- Scan Card -->
    <div class="card anim-1">
        <div class="card-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h7v7"/></svg>
            Scan / Enter Code
            <span class="card-line"></span>
        </div>
        <div class="scan-row">
            <div class="scan-field">
                <span class="scan-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h7v7"/></svg>
                </span>
                <input type="text"
                       id="inputCode"
                       class="scan-input"
                       placeholder="Scan QR or Enter Po Code…"
                       autocomplete="off"
                       onkeydown="if(event.key==='Enter') Dispatch.fetchByCode()" />
            </div>
            <div class="scan-btns">
                <button class="btn btn-primary" onclick="Dispatch.openScanner()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                    Scan QR
                </button>
                <button class="btn btn-ghost" onclick="Dispatch.fetchByCode()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    Fetch
                </button>
            </div>
        </div>
    </div>

    <!-- Material Banner (hidden until scan) -->
    <div class="mat-banner" id="matBanner">
        <div class="mat-img-wrap">
            <img id="matImage" src="" alt="material" />
        </div>
        <div class="mat-info">
            <div class="mat-name" id="matName">—</div>
            <div class="mat-code" id="matCode">HU: —</div>
            <div class="mat-pill">
                <span class="pulse-dot"></span> Data Loaded
            </div>
        </div>
    </div>

    <!-- PO Data + Line Items -->
    <div class="two-col">

        <div class="card anim-2">
            <div class="card-label">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Production Order Data
                <span class="card-line"></span>
            </div>
            <div class="tbl-wrap">
                <table id="poTable">
                    <thead>
                        <tr><th>  PO No</th><th>HU Code</th><th>Material</th><th>  No Of Cones</th></tr>
                    </thead>
                    <tbody>
                        <tr class="empty-row">
                            <td colspan="4">
                                    <span class="empty-ico">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14 2 14 8 20 8" />
                                            <line x1="16" y1="13" x2="8" y2="13" />
                                            <line x1="16" y1="17" x2="8" y2="17" />
                                        </svg>
                                    </span>
                                Scan a code to load PO
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card anim-3">
            <div class="card-label">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                Line Items
                <span class="card-line"></span>
            </div>
            <div class="tbl-wrap">
                <table id="lineTable">
                    <thead>
                        <tr><th>#</th><th>Name</th><th>Cone Wt.</th><th>Material</th></tr>
                    </thead>
                    <tbody>
                        <tr class="empty-row">
                            <td colspan="4">
                                    <span class="empty-ico">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="8" y1="6" x2="21" y2="6" />
                                            <line x1="8" y1="12" x2="21" y2="12" />
                                            <line x1="8" y1="18" x2="21" y2="18" />
                                            <line x1="3" y1="6" x2="3.01" y2="6" />
                                            <line x1="3" y1="12" x2="3.01" y2="12" />
                                            <line x1="3" y1="18" x2="3.01" y2="18" />
                                        </svg>
                                    </span>
                                No line items yet
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- Weight Card -->
    <div class="card anim-4">
        <div class="card-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            Weight Verification
            <span class="card-line"></span>
        </div>
        <div class="weight-section">
            <div class="wt-fields">
                <div class="field-grp">
                    <label class="field-lbl">Standard Weight</label>
                    <input type="number" id="stdWeight" class="field-inp" readonly placeholder="—" />
                </div>
                <div class="field-grp">
                    <label class="field-lbl">Actual Weight</label>
                    <input type="number" id="actWeight" class="field-inp" readonly placeholder="—" />
                </div>
            </div>
            <div class="wt-btns">
                <button class="btn btn-outline w-full" onclick="Dispatch.getWeight()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                    Fetch Weight
                </button>
                <button class="btn btn-primary w-full" onclick="Dispatch.confirmData()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Confirm &amp; Save
                </button>
            </div>
        </div>
    </div>

    <!-- Attachments Card
<div class="card anim-5"> 
     <div class="card-label"> 
         <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
             <rect x="3" y="3" width="18" height="18" rx="2"/>
             <circle cx="8.5" cy="8.5" r="1.5"/>
             <polyline points="21 15 16 10 5 21"/>
         </svg> 
        Attachments 
        <span class="card-line"></span>
    </div>
    <div class="attach-toolbar">
        <span class="attach-count" id="attachCount">0 files</span>
        <button class="btn btn-ghost btn-xs" onclick="Dispatch.loadDemoAttachments()">+ Demo Files</button>
    </div>
    <div class="attach-grid" id="attachGrid">
        <div class="attach-empty">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
            </svg>
            <p>No attachments. Scan a QR code to load files.</p>
        </div>
    </div>
</div>
-->

</main>


<!-- =============================================
     FOOTER
============================================= -->
<footer class="footer">
    <div class="footer-inner">
        <div class="footer-left">
            <span class="footer-brand">Aditya Birla Group</span>
            <span class="footer-divider">|</span>
            <span class="footer-module">Production Dispatch System</span>
        </div>
        <div class="footer-right">
            <span id="footerDate"></span>
            <span class="footer-divider">|</span>
            <span>v1.0.0</span>
            <span class="footer-divider">|</span>
            <span>Plant 1</span>
        </div>
    </div>
</footer>


<!-- =============================================
     IMAGE VIEWER MODAL
============================================= -->
<div class="overlay" id="viewerOverlay" onclick="Dispatch.closeViewer(event)">
    <div class="viewer-box">
        <div class="viewer-header">
            <span class="viewer-title" id="viewerTitle">Image</span>
                <div class="viewer-acts">
                    <button class="vbtn" onclick="Dispatch.rotateImg(-90)" title="Rotate Left">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2.5 2v6h6" />
                            <path d="M2.66 15.57a10 10 0 1 0 .57-8.38" />
                        </svg>
                    </button>
                    <button class="vbtn" onclick="Dispatch.rotateImg(90)" title="Rotate Right">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21.5 2v6h-6" />
                            <path d="M21.34 15.57a10 10 0 1 1-.57-8.38" />
                        </svg>
                    </button>
                    <button class="vbtn" onclick="Dispatch.zoomImg(0.25)" title="Zoom In">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            <line x1="11" y1="8" x2="11" y2="14" />
                            <line x1="8" y1="11" x2="14" y2="11" />
                        </svg>
                    </button>
                    <button class="vbtn" onclick="Dispatch.zoomImg(-0.25)" title="Zoom Out">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            <line x1="8" y1="11" x2="14" y2="11" />
                        </svg>
                    </button>
                    <button class="vbtn" onclick="Dispatch.resetImg()" title="Reset">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                            <path d="M3 3v5h5" />
                        </svg>
                    </button>
                    <button class="vbtn vbtn-close" onclick="Dispatch.closeViewer()" title="Close">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18" />
                            <line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                    </button>
                </div>
        </div>
        <div class="viewer-stage" id="viewerStage">
            <img id="viewerImg" src="" alt="preview" draggable="false" />
        </div>
        <div class="viewer-footer">
                <button class="vbtn" onclick="Dispatch.zoomImg(-0.25)" title="Zoom Out">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        <line x1="8" y1="11" x2="14" y2="11" />
                    </svg>
                </button>
                <span class="zoom-lbl" id="zoomLbl">100%</span>
                <button class="vbtn" onclick="Dispatch.zoomImg(0.25)" title="Zoom In">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        <line x1="11" y1="8" x2="11" y2="14" />
                        <line x1="8" y1="11" x2="14" y2="11" />
                    </svg>
                </button>
        </div>
    </div>
</div>


<!-- =============================================
     QR SCANNER MODAL
============================================= -->
<div class="overlay" id="qrOverlay">
    <div class="qr-box" onclick="event.stopPropagation()">
            <h3 class="qr-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                    <circle cx="12" cy="13" r="4" />
                </svg>
                Scan QR Code
            </h3>
        <div id="reader"></div>
        <div class="qr-footer">
                <button class="btn btn-ghost btn-sm" onclick="Dispatch.switchCamera()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 4v6h6" />
                        <path d="M23 20v-6h-6" />
                        <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10" />
                        <path d="M23 14l-4.64 4.36A9 9 0 0 1 3.51 15" />
                    </svg>
                    Flip Camera
                </button>
                <button class="btn btn-primary btn-sm" onclick="Dispatch.stopScanner()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                    Close
                </button>
        </div>
    </div>
</div>


<!-- =============================================
     LOADER
============================================= -->
<div class="loader-wrap" id="loader">
    <div class="spin-ring"></div>
</div>


<!-- =============================================
     TOAST CONTAINER
============================================= -->
<div id="toastWrap"></div>


<!-- =============================================
     SCRIPTS — All local, no CDN dependency
     html5-qrcode.min.js must be in wwwroot/js/
============================================= -->
<script src="~/js/html5-qrcode.min.js"></script>
<script src="~/js/dispatch.js"></script>

</body>
</html>
